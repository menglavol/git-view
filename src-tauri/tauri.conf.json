{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitView",
  "version": "1.0.0",
  "identifier": "com.gitview.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GitView",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Menglavoll/git-view/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwNEZFQ0FGRTkyNzA1M0YKUldRL0JTZnByK3hQVUtQaktGRmNmT2sybndKVFZUVVY4Y0pLL0FvN3FNMmswbzlUVHhPV2d5a0MK"
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 GitView Team",
    "targets": "all",
    "createUpdaterArtifacts": true,
    "shortDescription": "轻量级跨平台 Git 可视化客户端",
    "longDescription": "GitView 是一个支持 GitHub / GitLab / Gitee 多平台多账号管理的轻量级跨平台 Git 可视化客户端，聚焦多平台仓库统一浏览、批量克隆与日常 Git 操作可视化。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
